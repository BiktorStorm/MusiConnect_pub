Key changes from the original:

  - Adaptive sizing: shrinks buffer when underrun rate < 0.5%, grows when > 2%
  - Late packet drop: discards packets whose seq is more than 128 behind (already played)
  - Fixed error rate denominator: totalCount now increments on every pull, not just successes
  - Auto-initializes nextExpectedSeq from first received packet so you don't need external sync
  - Resets counters after each adapt window so the buffer reacts to current conditions, not history
class LowLatencyJitterBuffer {
    constructor(blockSize = 128, sampleRate = 48000) {
      this.blockSize = blockSize;
      this.sampleRate = sampleRate;
      this.numBlocks = 4;
      this.minBlocks = 2;
      this.maxBlocks = 12;
      this.buffer = new Array(256).fill(null);
      this.nextExpectedSeq = -1;
      this.seqMask = 0xFF;

      this.underrunCount = 0;
      this.totalCount = 0;
      this.adaptInterval = 200; // reassess every 200 pulls
    }

    put(audioData, seqNum) {
      if (this.nextExpectedSeq === -1) {
        this.nextExpectedSeq = seqNum;
      }

      let diff = (seqNum - this.nextExpectedSeq + 256) % 256;
      if (diff > 128) return; // too old, drop

      this.buffer[seqNum & this.seqMask] = audioData;
    }

    get() {
      const idx = this.nextExpectedSeq & this.seqMask;
      const data = this.buffer[idx];
      this.buffer[idx] = null;
      this.nextExpectedSeq = (this.nextExpectedSeq + 1) & this.seqMask;

      this.totalCount++;
      if (!data) {
        this.underrunCount++;
        if (this.totalCount % this.adaptInterval === 0) this.adapt();
        return new Float32Array(this.blockSize); // silence
      }

      if (this.totalCount % this.adaptInterval === 0) this.adapt();
      return data;
    }

    adapt() {
      const rate = this.underrunCount / this.totalCount;
      if (rate > 0.02 && this.numBlocks < this.maxBlocks) {
        this.numBlocks++;
      } else if (rate < 0.005 && this.numBlocks > this.minBlocks) {
        this.numBlocks--;
      }
      this.underrunCount = 0;
      this.totalCount = 0;
    }

    getBufferMs() {
      return (this.numBlocks * this.blockSize / this.sampleRate) * 1000;
    }
  }
